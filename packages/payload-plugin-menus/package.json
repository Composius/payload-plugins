    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf {dist,*.tsbuildinfo}"
  },
  "devDependencies": {
    "payload": "3.84.1",
    "rimraf": "3.0.2",
    "tsup": "8.5.0",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "payload": "^3.84.1"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
