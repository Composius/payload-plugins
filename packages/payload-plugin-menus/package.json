{
  "name": "@vitrailweb/payload-plugin-menus",
  "version": "0.3.2",
  "description": "Payload plugin that adds a Menus collection",
  "license": "MIT",
  "author": {
    "name": "Vitrail Web"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vitrail-Web/payload-plugins",
    "directory": "packages/payload-plugin-menus"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
