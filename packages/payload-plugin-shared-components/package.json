{
  "name": "@vitrailweb/payload-plugin-shared-components",
  "version": "0.1.0",
  "private": true,
  "description": "Shared building blocks (editor features, SEO field, access defaults) inlined into the Vitrail Web Payload plugins at build time",
  "license": "MIT",
  "author": {
    "name": "Vitrail Web"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vitrail-Web/payload-plugins",
    "directory": "packages/payload-plugin-shared-components"
  },
