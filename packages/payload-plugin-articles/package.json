{
  "name": "@vitrailweb/payload-plugin-articles",
  "version": "1.1.1",
  "description": "Payload plugin that adds an Articles collection",
  "license": "MIT",
  "author": {
    "name": "Vitrail Web"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vitrail-Web/payload-plugins",
    "directory": "packages/payload-plugin-articles"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "import": "./src/exports/client.ts",
      "types": "./src/exports/client.ts",
      "default": "./src/exports/client.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf {dist,*.tsbuildinfo}"
  },
  "devDependencies": {
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@types/react": "19.2.14",
    "@vitrailweb/payload-plugin-shared-components": "workspace:*",
    "payload": "3.84.1",
    "react": "19.2.6",
    "rimraf": "3.0.2",
    "tsup": "8.5.0",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "@payloadcms/plugin-nested-docs": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "payload": "^3.84.1",
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./client": {
        "import": "./dist/exports/client.js",
        "types": "./dist/exports/client.d.ts",
        "default": "./dist/exports/client.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
