{
  "name": "vitrailweb-payload-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Vitrail Web Payload plugins",
  "license": "MIT",
  "author": {
    "name": "Vitrail Web"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vitrail-Web/payload-plugins"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" build",
    "clean": "pnpm -r clean",
    "dev:articles": "cross-env DEV_SUITE=articles next dev dev --turbo",
    "dev:axiom": "cross-env DEV_SUITE=axiom next dev dev --turbo",
    "dev:custom-panel": "cross-env DEV_SUITE=custom-panel next dev dev --turbo",
    "dev:home-nav": "cross-env DEV_SUITE=home-nav next dev dev --turbo",
    "dev:media": "cross-env DEV_SUITE=media next dev dev --turbo",
    "dev:menus": "cross-env DEV_SUITE=menus next dev dev --turbo",
    "dev:pages": "cross-env DEV_SUITE=pages next dev dev --turbo",
    "dev:umami": "cross-env DEV_SUITE=umami next dev dev --turbo",
    "generate:importmap:articles": "cross-env DEV_SUITE=articles pnpm payload generate:importmap",
    "generate:importmap:custom-panel": "cross-env DEV_SUITE=custom-panel pnpm payload generate:importmap",
    "generate:importmap:home-nav": "cross-env DEV_SUITE=home-nav pnpm payload generate:importmap",
    "generate:importmap:pages": "cross-env DEV_SUITE=pages pnpm payload generate:importmap",
    "generate:importmap:umami": "cross-env DEV_SUITE=umami pnpm payload generate:importmap",
    "generate:types:articles": "cross-env DEV_SUITE=articles pnpm payload generate:types",
    "generate:types:axiom": "cross-env DEV_SUITE=axiom pnpm payload generate:types",
    "generate:types:custom-panel": "cross-env DEV_SUITE=custom-panel pnpm payload generate:types",
    "generate:types:home-nav": "cross-env DEV_SUITE=home-nav pnpm payload generate:types",
    "generate:types:media": "cross-env DEV_SUITE=media pnpm payload generate:types",
    "generate:types:menus": "cross-env DEV_SUITE=menus pnpm payload generate:types",
    "generate:types:pages": "cross-env DEV_SUITE=pages pnpm payload generate:types",
    "generate:types:umami": "cross-env DEV_SUITE=umami pnpm payload generate:types",
    "lint": "eslint",
    "lint:fix": "eslint packages dev --fix",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "test": "pnpm test:unit && pnpm test:int && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest run dev/configs",
    "test:unit": "vitest run packages",
    "typecheck": "tsc --noEmit && tsc --noEmit -p dev/configs/articles && tsc --noEmit -p dev/configs/axiom && tsc --noEmit -p dev/configs/custom-panel && tsc --noEmit -p dev/configs/home-nav && tsc --noEmit -p dev/configs/media && tsc --noEmit -p dev/configs/menus && tsc --noEmit -p dev/configs/pages && tsc --noEmit -p dev/configs/umami"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@playwright/test": "1.58.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitrailweb/payload-plugin-articles": "workspace:*",
    "@vitrailweb/payload-plugin-axiom": "workspace:*",
    "@vitrailweb/payload-plugin-custom-panel": "workspace:*",
    "@vitrailweb/payload-plugin-home-nav": "workspace:*",
    "@vitrailweb/payload-plugin-media": "workspace:*",
    "@vitrailweb/payload-plugin-menus": "workspace:*",
    "@vitrailweb/payload-plugin-pages": "workspace:*",
    "@vitrailweb/payload-plugin-umami": "workspace:*",
    "cross-env": "^7.0.3",
    "eslint": "^9.23.0",
    "eslint-config-next": "16.2.6",
    "graphql": "^16.8.1",
    "mongodb-memory-server": "10.1.4",
    "next": "16.2.6",
    "open": "^10.1.0",
    "payload": "3.84.1",
    "prettier": "^3.4.2",
    "qs-esm": "8.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2",
    "sort-package-json": "^2.10.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}
