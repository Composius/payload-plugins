{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@payload-config": ["./payload.config.ts"]
    },
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.ts",
    "**/*.tsx",
    "next.config.mjs",
    ".next/types/**/*.ts"
  ],
  // Each suite's payload-types.ts augments the payload module with its own
  // generated types; combined in one program they conflict, so files that
  // depend on the augmentation are checked by per-suite tsconfigs instead
  // (dev/configs/<suite>/tsconfig.json).
  "exclude": ["configs/*/payload-types.ts", "configs/*/int.spec.ts"]
}
